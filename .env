# ---------------------------------------------------------------------------
# LOCAL DEV DEFAULTS (safe to commit — no real secrets here).
# Override real secrets in .env.local (gitignored) or your host's env settings.
# ---------------------------------------------------------------------------

# SQLite for zero-config local dev. For production, switch the datasource
# provider in prisma/schema.prisma to "postgresql" and set this to your
# Postgres connection string (e.g. Supabase/Neon).
DATABASE_URL="file:./dev.db"

# Auth.js session signing secret. This is a DEV-ONLY value — generate a real
# one for production with:  openssl rand -base64 32
AUTH_SECRET="dev-only-secret-please-change-in-production-0000000000="
AUTH_TRUST_HOST="true"

# AI provider (Claude). Leave empty to run the app with a graceful fallback
# tutor; set a real key to make the AI Tutor + project evaluation live.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
