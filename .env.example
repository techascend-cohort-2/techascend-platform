# Copy to .env.local and fill in real values.
# No .env file is committed to this repo — see README "Database setup".

# --- Database (Postgres — required) ---
# Matches docker-compose.yml for zero-account local dev:
#   docker compose up -d
DATABASE_URL="postgresql://techascend:techascend@localhost:5432/techascend?schema=public"
# Or point at a hosted Postgres (Supabase/Neon/Vercel Postgres). See
# DEPLOYMENT.md for the full production checklist.

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Set to "true" behind a proxy / on platforms that don't set the host header.
AUTH_TRUST_HOST="true"

# --- AI ---
# The platform key — used ONLY for project evaluation. The AI Tutor runs on
# each student's own key (Gemini / Claude / OpenAI), saved in their profile.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional model overrides (defaults shown).
ANTHROPIC_MODEL="claude-sonnet-5"
# GEMINI_MODEL="gemini-2.0-flash"
# OPENAI_MODEL="gpt-4o-mini"
