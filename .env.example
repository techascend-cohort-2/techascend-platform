# Copy to .env.local and fill in real values for production.

# --- Database ---
# Local dev (default): SQLite
DATABASE_URL="file:./dev.db"
# Production: Postgres (also change datasource provider to "postgresql" in
# prisma/schema.prisma). Example (Supabase):
# DATABASE_URL="postgresql://user:pass@host:5432/postgres?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Set to "true" behind a proxy / on platforms that don't set the host header.
AUTH_TRUST_HOST="true"

# --- AI (Claude / Anthropic) ---
# Required to make the AI Tutor and project evaluation live.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional model override (defaults to claude-sonnet-5).
ANTHROPIC_MODEL="claude-sonnet-5"
